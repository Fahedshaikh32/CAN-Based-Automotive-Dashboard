cstackCOMRAM COMRAM 1 1 1 21 1 1
smallconst SMALLCONST 0 600 600 2 1 2
dataCOMRAM COMRAM 1 22 22 B 1 1
bssCOMRAM COMRAM 1 2D 2D 7 1 1
$C:\Users\Fahed\AppData\Local\Temp\xcAs3t8.0\driver_tmp_9.o
